@model IEnumerable<CommunityLibrary.Models.Loan>
@{
    ViewData["Title"] = "Overdue Loans";
}

<h1>Overdue Loans</h1>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <h4 class="alert-heading">No Overdue Loans!</h4>
        <p>Great job! All books have been returned on time.</p>
        <hr>
        <a asp-action="Index" class="btn btn-outline-success">Back to Loans</a>
    </div>
}
else
{
    <div class="alert alert-danger">
        <h4 class="alert-heading">@Model.Count() Overdue Loan(s)</h4>
        <p>These books are past their due date and need to be returned.</p>
    </div>
    
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Book</th>
                <th>Member</th>
                <th>Loan Date</th>
                <th>Due Date</th>
                <th>Days Overdue</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in Model)
            {
                var daysOverdue = (DateTime.Now - loan.DueDate).Days;
                <tr>
                    <td>@loan.Book?.Title</td>
                    <td>@loan.Member?.FullName</td>
                    <td>@loan.LoanDate.ToShortDateString()</td>
                    <td>@loan.DueDate.ToShortDateString()</td>
                    <td>
                        <span class="badge bg-danger">@daysOverdue days</span>
                    </td>
                    <td>
                        <form asp-action="Return" method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@loan.Id" />
                            <button type="submit" class="btn btn-sm btn-success" 
                                    onclick="return confirm('Mark this book as returned?')">
                                Return Book
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Loans</a>
    </div>
}