@{
    ViewData["Title"] = "Create Loan";
}

<h1>Create New Loan</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5>Select Book and Member</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Select Book</label>
                        <select name="bookId" class="form-select" required>
                            <option value="">-- Choose a book --</option>
                            @foreach (var book in ViewBag.Books)
                            {
                                <option value="@book.Id">
                                    @book.Title by @book.Author (ISBN: @book.Isbn)
                                </option>
                            }
                        </select>
                        @if (ViewBag.Books.Count == 0)
                        {
                            <div class="alert alert-warning mt-2">
                                No books available for loan. 
                                <a asp-controller="Books" asp-action="Index">Check books</a>
                            </div>
                        }
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Select Member</label>
                        <select name="memberId" class="form-select" required>
                            <option value="">-- Choose a member --</option>
                            @foreach (var member in ViewBag.Members)
                            {
                                <option value="@member.Id">
                                    @member.FullName - @member.Email
                                </option>
                            }
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary" @(ViewBag.Books.Count == 0 ? "disabled" : "")>
                            Create Loan
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>Loan Rules</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li class="mb-2">📚 Loan period: <strong>14 days</strong></li>
                    <li class="mb-2">⏰ Due date calculated automatically</li>
                    <li class="mb-2">✅ Books must be available</li>
                    <li class="mb-2">🔄 Return books to make them available again</li>
                </ul>
            </div>
        </div>
    </div>
</div>