@model IEnumerable<CommunityLibrary.Models.Book>
@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</p>

<!-- Search and Filter Form - This is worth 20 marks! -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Search & Filter Books</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" id="filterForm">
            <div class="row">
                <!-- Search box -->
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label fw-bold">Search by Title or Author</label>
                        <input type="text" name="searchString" class="form-control" 
                               value="@ViewBag.CurrentSearch" 
                               placeholder="Enter title or author..." />
                    </div>
                </div>
                
                <!-- Category dropdown -->
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label fw-bold">Category</label>
                        <select name="category" class="form-select">
                            <option value="All" selected="@(ViewBag.CurrentCategory == "All")">All Categories</option>
                            @foreach (var category in ViewBag.Categories)
                            {
                                <option value="@category" selected="@(ViewBag.CurrentCategory == category)">
                                    @category
                                </option>
                            }
                        </select>
                    </div>
                </div>
                
                <!-- Availability dropdown -->
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label fw-bold">Availability</label>
                        <select name="availability" class="form-select">
                            <option value="All" selected="@(ViewBag.CurrentAvailability == "All")">All</option>
                            <option value="Available" selected="@(ViewBag.CurrentAvailability == "Available")">Available</option>
                            <option value="OnLoan" selected="@(ViewBag.CurrentAvailability == "OnLoan")">On Loan</option>
                        </select>
                    </div>
                </div>
                
                <!-- Buttons -->
                <div class="col-md-2 d-flex align-items-end">
                    <div class="btn-group w-100">
                        <button type="submit" class="btn btn-primary">Apply Filters</button>
                        <a asp-action="Index" class="btn btn-secondary">Clear</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results count -->
<div class="mb-3">
    <strong>@Model.Count()</strong> books found
</div>

<!-- Books table -->
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Isbn</td>
                <td>@book.Category</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No books found. Try adjusting your filters or <a asp-action="Create">create a new book</a>.
    </div>
}
